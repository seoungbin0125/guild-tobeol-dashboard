rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /guidePosts/{postId} {
      allow read: if true;

      // 길드 내부용 초간단 게시판 규칙입니다.
      // 서버 없이 GitHub Pages에서 바로 쓰기 위한 설정이라 누구나 API를 직접 호출하면 글을 쓸 수 있습니다.
      // 진짜 관리자 보안이 필요하면 Firebase Authentication 방식으로 전환하세요.
      allow create: if request.resource.data.keys().hasOnly([
          'title', 'content', 'author', 'category', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 1
        && request.resource.data.title.size() <= 80
        && request.resource.data.content is string
        && request.resource.data.content.size() >= 1
        && request.resource.data.content.size() <= 8000
        && request.resource.data.author is string
        && request.resource.data.author.size() <= 30
        && request.resource.data.category is string
        && request.resource.data.category.size() <= 20;

      allow update: if false;
      allow delete: if true;
    }
  }
}
